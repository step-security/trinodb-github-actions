{
  "name": "slash-command-dispatch",
  "version": "4.0.0",
  "private": true,
  "description": "Facilitates 'ChatOps' by creating dispatch events for slash commands",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc && ncc build",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "test": "jest unit",
    "test:int": "jest int"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/slash-command-dispatch.git"
  },
  "keywords": [
    "slash",
    "command",
    "dispatch"
  ],
  "author": "step-security",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/step-security/slash-command-dispatch/issues"
  },
  "homepage": "https://github.com/step-security/slash-command-dispatch#readme",
  "dependencies": {
    "@actions/core": "^2.0.0",
    "@actions/github": "^6.0.0",
    "@octokit/core": "^5.2.2",
    "@octokit/plugin-paginate-rest": "^9.2.2",
    "@octokit/plugin-rest-endpoint-methods": "^6.8.1",
    "axios": "^1.17.0",
    "http-proxy-agent": "^5.0.0",
    "https-proxy-agent": "^5.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.57.0",
    "eslint-plugin-github": "^5.0.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-jest": "^28.8.0",
    "eslint-plugin-prettier": "^5.2.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
  }
